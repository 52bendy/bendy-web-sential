# bendy-web-sential Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: .env must be in .gitignore

# Server Ports
BWS_GATEWAY_PORT=8080
BWS_ADMIN_PORT=3000

# Database
BWS_DATABASE_URL=data/bws.db

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
BWS_JWT_SECRET=changeme-use-openssl-rand-base64-32
BWS_JWT_EXPIRY_SECS=86400

# Logging
BWS_LOG_LEVEL=info

# TOTP AES Encryption Key (Phase 4, optional in Phase 1)
# Generate: openssl rand -hex 32
# BWS_TOTP_AES_KEY=
