# bendy-web-sential Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: .env must be in .gitignore

# Server Ports
BWS_GATEWAY_PORT=8080
BWS_ADMIN_PORT=3000

# Database
BWS_DATABASE_URL=data/bws.db

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
BWS_JWT_SECRET=changeme-use-openssl-rand-base64-32
BWS_JWT_EXPIRY_SECS=86400

# Logging
BWS_LOG_LEVEL=info

# TOTP AES Encryption Key (Phase 4, required for TOTP)
# Generate: openssl rand -base64 32
BWS_TOTP_AES_KEY=changeme-use-openssl-rand-base64-32

# Rate Limiting
BWS_RATE_LIMIT_REQUESTS_PER_SEC=100
BWS_RATE_LIMIT_BURST=200

# Circuit Breaker
BWS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
BWS_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
BWS_CIRCUIT_BREAKER_TIMEOUT_SECS=30

# Retry Configuration
BWS_RETRY_MAX_ATTEMPTS=3
BWS_RETRY_BASE_DELAY_MS=100
